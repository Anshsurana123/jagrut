<!--
    Neural HUD: Holographic Response History Item
    Design: jagrut_holographic_response — glass card AI response log
    Required IDs: txtQuery, txtActionType, txtTimestamp, txtIntentDescription, txtPayloadDetails
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="16dp">

    <!-- Neural orb + response card row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="top">

        <!-- Neural orb avatar indicator -->
        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/neural_status_orb"
            android:layout_marginEnd="12dp"
            android:layout_marginTop="10dp" />

        <!-- Glass holographic response card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/glass_card_premium"
            android:orientation="vertical"
            android:padding="14dp">

            <!-- Top row: Timestamp + Action Type chip -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <!-- Action type badge -->
                <TextView
                    android:id="@+id/txtActionType"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTION"
                    android:textColor="@color/neural_teal"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.1"
                    android:textAllCaps="true"
                    android:background="@drawable/hud_glass_card_teal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp"
                    android:layout_marginEnd="8dp" />

                <!-- Timestamp -->
                <TextView
                    android:id="@+id/txtTimestamp"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00:00"
                    android:textColor="@color/text_tertiary"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.04" />

            </LinearLayout>

            <!-- Query text -->
            <TextView
                android:id="@+id/txtQuery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text='Query: "..."'
                android:textColor="@color/on_surface"
                android:textSize="13sp"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="6dp" />

            <!-- Teal separator -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@drawable/hud_separator"
                android:layout_marginBottom="8dp" />

            <!-- Intent description -->
            <TextView
                android:id="@+id/txtIntentDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Intent loading..."
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.4"
                android:layout_marginBottom="6dp" />

            <!-- Payload details -->
            <TextView
                android:id="@+id/txtPayloadDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/neural_teal"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.04" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
