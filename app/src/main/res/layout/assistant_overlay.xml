<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- Glowing Frosted Glass Bottom Panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_margin="24dp"
        android:background="@drawable/glass_card"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="18dp"
        android:paddingBottom="18dp"
        android:elevation="16dp"
        android:minHeight="120dp">

        <!-- Glowing Accent Indicator -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:background="@color/brand_secondary"
            android:layout_marginBottom="12dp" />

        <com.example.jago.ui.GlowSphereView
            android:id="@+id/overlayGlowSphere"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/overlayStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="Listening..."
            android:textSize="18sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <TextView
            android:id="@+id/overlayPartialText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text=""
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="6dp"
            android:maxLines="2"
            android:ellipsize="end"
            android:textAlignment="center" />

        <!-- Live Telemetry Terminal Dashboard -->
        <LinearLayout
            android:id="@+id/layoutTelemetry"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/glass_card"
            android:orientation="vertical"
            android:padding="10dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/txtTelemetry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:typeface="monospace"
                android:textColor="@color/text_primary"
                android:textSize="11sp"
                android:maxLines="4"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- High-End Circular / Dynamic Indeterminate Loader -->
        <ProgressBar
            android:id="@+id/overlayProgressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:indeterminate="true"
            android:layout_marginTop="16dp"
            android:progressTint="@color/brand_secondary"
            android:indeterminateTint="@color/brand_secondary"
            android:visibility="visible"/>

    </LinearLayout>

    <!-- Floating Actions: Settings or Schedule Shortcut -->
    <ImageButton
        android:id="@+id/btnSchedule"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="@drawable/glass_card"
        android:src="@android:drawable/ic_menu_my_calendar"
        android:padding="8dp"
        android:scaleType="fitCenter"
        app:tint="@color/text_primary" />

</FrameLayout>
