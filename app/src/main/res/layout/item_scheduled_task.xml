<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:background="@drawable/glass_card"
    android:orientation="horizontal"
    android:padding="16dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTaskType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SEND MESSAGE"
            android:textColor="@color/brand_secondary"
            android:textStyle="bold"
            android:textSize="14sp"
            android:letterSpacing="0.02" />

        <TextView
            android:id="@+id/tvTaskDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="To: Mom \nMessage: Hello"
            android:textColor="@color/text_primary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvTriggerTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="At 7:00 PM"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnCancel"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:padding="8dp"
        android:scaleType="fitCenter"
        app:tint="@color/alert_red"
        android:layout_marginStart="8dp" />

</LinearLayout>
