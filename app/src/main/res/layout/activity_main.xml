<!--
    JAGRUT — Neural HUD Main Activity
    Design: Sentient AI Interface 2075 (jagrut_home_core)
    Top Bar: J A G R U T title + live clock
    Bottom: Floating pill navigation (glass + luminous border)
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_void">

    <!-- ─── Animated Neural Background ─── -->
    <com.example.jago.ui.FuturisticBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- ─── Full-screen Content ─── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ─── HUD Top App Bar ─── -->
        <LinearLayout
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="#1AFFFFFF">

            <!-- Hexagon / Menu icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⬡"
                android:textSize="20sp"
                android:textColor="@color/text_secondary" />

            <!-- J A G R U T title -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="J  A  G  R  U  T"
                android:textColor="@color/brand_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                android:letterSpacing="0.4"
                android:fontFamily="sans-serif-medium" />

            <!-- Live System Clock -->
            <TextView
                android:id="@+id/tvSystemClock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00:00"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.06" />
        </LinearLayout>

        <!-- 1dp luminous separator below header -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@drawable/hud_separator" />

        <!-- ─── ViewPager2 (Swipeable Tabs) ─── -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@android:color/transparent" />

    </LinearLayout>

    <!-- ─── Floating Neural Pill Navigation ─── -->
    <!--
        Positioned at the bottom, floating above content
        Matches: jagrut_home_core BottomNavBar
        Glass background + luminous teal-violet gradient border
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_gravity="bottom"
        android:background="@drawable/neural_nav_pill"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="20dp"
        android:elevation="16dp"
        app:itemIconTint="@color/text_secondary"
        app:itemTextColor="@color/text_secondary"
        app:itemRippleColor="@color/teal_glow"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/bottom_nav_menu"
        app:elevation="8dp" />

</FrameLayout>
